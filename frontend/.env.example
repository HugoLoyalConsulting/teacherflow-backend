# TeacherFlow - Frontend Environment Variables

# Environment (development, qa, production)
VITE_ENVIRONMENT=qa

# API
VITE_API_URL=https://backend-production-c4f8f.up.railway.app/api/v1
VITE_API_TIMEOUT=30000

# Auth
VITE_JWT_STORAGE_KEY=teacherflow_token
VITE_USER_STORAGE_KEY=teacherflow_user

# Google OAuth (Optional)
# Register your app at https://console.developers.google.com
# Create OAuth 2.0 credentials (Client ID for Web application)
# Leave empty to disable Google Sign-In
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# PostHog Analytics (Optional)
# Sign up at https://app.posthog.com
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_KEY=phc_your_posthog_project_key
VITE_POSTHOG_HOST=https://app.posthog.com

# Sentry Error Monitoring (Optional)
# Sign up at https://sentry.io
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

