# Database
DATABASE_URL=postgresql://teacherflow:teacherflow123@localhost:5432/teacherflow

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
DEBUG=true
API_V1_STR=/api/v1
ENVIRONMENT=development

# Monitoring & Telemetry
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

POSTHOG_ENABLED=false
POSTHOG_API_KEY=phc_your_posthog_project_key
POSTHOG_HOST=https://app.posthog.com

# Database for docker-compose
DB_USER=teacherflow
DB_PASSWORD=teacherflow123
DB_NAME=teacherflow

# Email / SMTP (Email Verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@teacherflow.app

# Note: For Gmail, create an App Password:
# 1. Go to Google Account → Security
# 2. Enable 2-Step Verification
# 3. Go to App Passwords → Generate
# 4. Use the generated password (16 chars)
